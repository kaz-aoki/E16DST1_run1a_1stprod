double lconst_func_106_100(double *val, double *pars){
  double x     = -1*val[0];
  double y     = -1*val[1];
  /*
  double yA1   = (-218.3  +  0.226*y  -0.035*y*y);
  double yA2   = (-6.73   +  0.351*y  -0.0013*y*y - 0.00016*y*y*y);
  double dt    = 250+yA1*TMath::Gaus(x,yA2,40);
  */
  //double dt    = (23.5+0.57*y-0.028*y*y-0.0003*y*y*y)+(0.77-0.044*y-5.4e-5*y*y+2.2e-5*y*y*y)*x+(0.078+0.00024*y-2.86e-6*y*y)*x*x;
  //double dt    = (10.7+0.058*y-0.01*y*y)+x*(0.54-0.024*y-2.7e-5*y*y+1.3e-5*y*y*y)+x*x*(0.025+0.00027*y);
  //double dl    = (-0.78*TMath::Gaus(y,2.74,30.7)+0.9)*TMath::Gaus(x,(-24*TMath::Gaus(y,-7.3,11.8)+0.06),25)-0.35;
  //double dl2   = (-0.25*TMath::Gaus(y,0.4,14.5))*(1./(exp(0.14*(abs(x+1)-37))+1)-1);
  double dt    = (-0.3+0.35*y-0.024*y*y+3.8e-5*y*y*y+1.6e-5*y*y*y*y)+x*(0.75+0.0049*y-0.00075*y*y)+x*x*(0.024-0.0012*y-2.6e-5*y*y+7.2e-7*y*y*y);
  if(dt> 50) dt =  50;
  if(dt<-50) dt = -50;
  
  double dl    = (-0.48*TMath::Gaus(y,-10,19)+0.05)*TMath::Gaus(x,20,40)+
    +(-0.023-0.0046*y+0.0008*y*y+1.7e-6*y*y*y-2.7e-7*y*y*y*y)*TMath::Gaus(x,0,25)+(0.05-0.0038*y-0.0006*y*y+1.6e-6*y*y*y+2.3e-7*y*y*y*y);
  double dl2   = (-0.3+TMath::Gaus(y,-24,8.4)+1.5*TMath::Gaus(y,22,14))*(0.2-0.4/(exp(0.2*(fabs(x)-38))+1)+0.25*TMath::Gaus(x,5,18));
  return (dl + dl2 +0.007*(dt*0.75));
  
  //return 0;
}




double lconst_func_106_200(double  *val, double *pars){
  Double_t x = val[0];
  Double_t y = val[1];

  //double dt  =  -1*(300*TMath::Gaus(x,(-18*TMath::Gaus(y,-34,24)+0.3),110)+(-325-0.6*y+0.016*y*y+5.6e-5*y*y*y-1.47e-6*y*y*y*y));
  //double dt2 =  -1*(150+(-151-0.16*y-0.01*y*y+3.1e-5*y*y*y+1.4e-6*y*y*y*y)*TMath::Gaus(x,0,(79-0.45*y-0.0085*y*y+6.3e-5*y*y*y+2.1e-6*y*y*y*y)));
  double dt  =  -1*((-5.7+0.062*y+0.0034*y*y)+x*(0.24+0.00019*y-0.00015*y*y+6.5e-8*y*y*y+1.4e-8*y*y*y*y)+x*x*(0.006-2.1e-5*y-2.8e-6*y*y));
  if(dt> 50) dt =  50;
  if(dt<-50) dt = -50;
  double dl = (0.47/(exp(0.2*(fabs(y+5)-90))+1)-0.2)*TMath::Gaus(x,(-54-0.25*y+0.009*y*y),40)-0.08+(0.0033/(exp(0.2*(fabs(y-25)-63))+1)-0.0015)*x;
  return -1*(dl + 0.006*(dt*0.8));
  
  //return 0;
}

double lconst_func_106_300(double *val, double *pars){
  Double_t x = val[0];
  Double_t y = val[1];
  
  //double dt = -1*(118+0.027*y-0.007*y*y)+40;
  //double dt = -1*((204-0.27*y+0.002*y*y)*TMath::Gaus(x,(5.6+0.9*y+0.007*y*y-6e-5*y*y*y-7.6e-7*y*y*y*y),130)-200);
  
  double dt = -1*((27.6+0.75*y+0.0016*y*y-3.8e-5*y*y*y-2.5e-7*y*y*y*y)+x*x*(-0.012-0.00011*y-5.5e-7*y*y+9.6e-9*y*y*y+9.3e-11*y*y*y*y));
  if(dt> 100) dt =  100;
  if(dt<-100) dt = -100;

  //double dt = 0;
  double dl  = (1.05-0.5*(TMath::Gaus(y,67,24)+TMath::Gaus(y,-64,24)))*TMath::Gaus(x,(44+0.41*y-0.0046*y*y),80)
    -0.7+(-0.0043-1.2e-5*y+7.5e-7*y*y+1.7e-10*y*y*y-3e-11*y*y*y*y)*x;
  double dl2 = (0.45+0.001*y-3e-5*y*y)*TMath::Gaus(x,(-20-0.78*y-0.012*y*y+9e-5*y*y*y+8.4e-7*y*y*y*y),35)
    +(0.44+0.001*y-2.9e-5*y*y)*TMath::Gaus(x,90+0.19*y+0.00057*y*y-1e-6*y*y*y,25)
    +(-0.37-0.00024*y+1.6e-5*y*y);

    
  return -1*(dl + dl2 + 0.004*dt*0.75);
  //return -1*0.004*dt;
}

double t0_func_107_100_200_300(double *val, double *pars){
  double xx   = val[0];
  double yy   = val[1];
  double mag  = pars[0];
  double sx   = pars[1];
  double mx   = pars[2];
  double sy   = pars[3];
  double my   = pars[4];
  double ped  = pars[5];
  double argx = (xx-sx)/mx;
  double argy = (yy-sy)/my;
  return mag*exp(-0.5*argx*argx)*exp(-0.5*argy*argy)+ped;
  
}

double lconst_func_107_100(double *val, double *par){
  double xx   = val[0];
  double yy   = -1*val[1];
  double p0   = par[0];
  double p1   = par[1];
  double p2   = par[2];
  double p3   = par[3];
  double p4   = par[4];
  double s0   = par[5];
  double s1   = par[6];
  //double lc   = par[7];
    
  double pol  = p0+p1*yy+p2*yy*yy+p3*yy*yy*yy+p4*yy*yy*yy*yy;
  double st   = s0/(exp(0.3*(abs(yy-3)+s1))+1)-0.15;

  double argx = (xx)/20;
  //return -1*(st*exp(-0.5*argx*argx)+pol)+lc;
  return -1*(st*exp(-0.5*argx*argx)+pol);
}

double lconst_func_107_200(double *val, double *par){
  double xx    = -1*val[0];
  double yy    = val[1];
  double p0    = par[0];
  double p1    = par[1];
  double p2    = par[2];
  double p3    = par[3];
  double p4    = par[4];
  double s0    = par[5];
  double s1    = par[6];
  double ss0   = par[7];
  double ss1   = par[8];
  //double lc    = par[9];
  
  double pol   = p0+p1*yy+p2*yy*yy+p3*yy*yy*yy+p4*yy*yy*yy*yy;
  double st1   = s0/(exp(0.25*(-yy+s1))+1);
  double st2   = ss0/(exp(0.2*(abs(yy)+ss1))+1);
  double argx  = (xx+100)/35;
  double argx2 = (xx-70)/40;
  
  //return st2*exp(-0.5*argx*argx)+pol+st1*exp(-0.5*argx2*argx2)+lc;
  return st2*exp(-0.5*argx*argx)+pol+st1*exp(-0.5*argx2*argx2);
}
  
