double fgeom_func_104_100(double *val, double *par){
  double x  = -1*val[0];
  double y  = -1*val[1];

  double ret = -0.6/(exp(0.18*(x+(-37.8+0.14*y-0.0020*y*y) ))+1)+0.6/(exp(0.18*(-x+(-36-0.011*y-0.00157*y*y)))+1);
  double cor = -0.4/(exp(0.3*(x+(-42+0.068*y-0.004*y*y)))+1)+0.4/(exp(0.3*(-x+(-42-0.12*y+0.0004*y*y)))+1);
  
  return -1*(ret+cor);
  //return -1*(-0.65/(exp(0.15*(xx-50))+1)+0.65/(exp(0.15*(-xx-42))+1));
  //return 0;
}

double fgeom_func_104_200(double *val, double *par){
  double x  = val[0];
  double y  = val[1];
  double ret = (0.065+3.34e-6*y+4.07e-6*y*y)+x*(0.00082+6.78e-6*y+4.2e-7*y*y);
  return ret;
  //return 0.5/(exp(0.2*(fabs(xx+5)-75))+1)-0.45;
  //return 0;
}

double fgeom_func_104_300(double *val, double *par){
  double x   = val[0];
  double y   = val[1];
  double ret = (-1.06-0.00038*y+5.1e-5*y*y)/(exp(0.1*(x-100))+1)+(0.94+0.00044*y-5.5e-5*y*y)
    +(0.00054+1.2e-5*y-4.8e-7*y*y-1.4e-9*y*y*y+2.4e-11*y*y*y*y)*x;
  return ret;
  //return 0;
}


double fgeom_func_106_100(double *val, double *par){
  double x   = -1*val[0];
  double y   = -1*val[1];
  //double ret = -0.6/(exp(0.3*(x+(-37+0.0059*y-0.0038*y*y)))+1)+0.6/(exp(0.3*(-x+(-42+0.049*y-0.0025*y*y)))+1);
  //double ret = -0.75/(exp(0.14*(x+(-41-0.082*y-0.0042*y*y+0.00011*y*y*y)))+1)+0.75/(exp(0.14*(-x+(-45+0.25*y-0.0049*y*y-6.2e-5*y*y*y)))+1)-0.003*x;
  double ret = -0.35/(exp(0.14*(x+(-36.7-0.054*y-0.0077*y*y)))+1)+0.35/(exp(0.14*(-x+(-37-0.093*y-0.005*y*y+0.00011*y*y*y)))+1)-0.0035*x;
  return -1*ret;
  //return 0;
}

  
double fgeom_func_106_200(double *val, double *par){
  double x   = val[0];
  double y   = val[1];
  //double ret = (-0.012-0.00036*y+9e-7*y*y+1.45e-7*y*y*y)+x*(0.00055+2.4e-5*y+2.9e-7*y*y);
  double ret = (-0.00075+2.1e-6*y+2.8e-7*y*y)*x+0.25/(exp(0.25*(-x+88))+1);
  return ret;  
  //return 0;
}

double fgeom_func_106_300(double *val, double *par){
  double x   = val[0];
  double y   = val[1];
  //return 0;
  //double ret = (-1.3/(exp(0.13*(-fabs(y+5)+125))+1)+0.0036*y-0.45)*(TMath::Gaus(x,(-52-0.23*y+0.0038*y*y),90)-1)
  //+(-0.16-0.0018*y+2.6e-5*y*y+1.6e-7*y*y*y-1.4e-9*y*y*y*y)+0.0019*x;
  double ret = -0.75/(exp(0.1*(x+(-82-0.004*y-0.004*y*y-2.7e-6*y*y*y+1.4e-7*y*y*y*y)))+1)
    +(0.0029-1.1e-5*y-3.8e-7*y*y)*x+(0.65-0.0007*y+2.3e-5*y*y-3.3e-9*y*y*y-1.2e-9*y*y*y*y);
  return ret;

}

