}

double lconst_func_104_300(double *val, double *pars){
  double x  = val[0];
  double y  = val[1];
  
  double dt = 350*TMath::Gaus(x,(-27*TMath::Gaus(y,-12.5,43)+15),110)-300;
  if(x<0&&dt<0) dt = 0;
  dt = -1*dt;
  double dl1 = (0.84+0.003*y-5.2e-5*y*y-9.7e-7*y*y*y+4.2e-9*y*y*y*y+3.5e-11*y*y*y*y*y)/(exp(0.04*(fabs(x+30)-120))+1)-0.9+(0.0009-2e-6*y)*x;
  double dl2 = 0.14/(exp(0.2*(-y+100))+1)+x*(0.002/(exp(0.3*(y+125))+1));
  
  double y1 =-63-0.1*y-0.001*y*y+1.5e-5*y*y*y;
  double y2 =0.32+0.0019*y-2.3e-5*y*y-2.5e-7*y*y*y+2.0e-9*y*y*y*y;
  if(y2>0.55) y2=0.55;
  double y3 =119+0.3*y-0.013*y*y-1.6e-5*y*y*y+6e-7*y*y*y*y;
  double y4 =38-0.21*y-0.001*y*y+2.4e-5*y*y*y+1.3e-7*y*y*y*y;
  if(y4>100) y4=100;
  double y5 =109+0.19*y-0.018*y*y-0.00013*y*y*y;
  if(y5<30) y5=30;
  double dl3 = 0.35*TMath::Gaus(x,y1,y4)+y2*TMath::Gaus(x,y3,y5)-0.3;
  return -1*(dl1 + dl2 + dl3 + 0.0039*dt);
  /*
  double x  = val[0];
  double y  = val[1];
  double ys = y*0.01;
  double p0 = -0.036 +0.19*ys -0.25*ys*ys -0.71*ys*ys*ys +0.15*ys*ys*ys*ys +0.35*ys*ys*ys*ys*ys;
  double p1 =  0.314;
  double p2 =  0.027;
  double p3 =  3.18  +0.27*ys +1.61*ys*ys +0.24*ys*ys*ys -1.46*ys*ys*ys*ys;
  double func = p0 + p1*sin( p2*x+p3 );
  return -func;
  */
}

double t0_func_106_100(double *val, double *pars){
  double x     = -1*val[0];
  double y     = -1*val[1];
  
  //double yA1    = (-218.3  +  0.226*yy  -0.035*yy*yy);
  //double yA2    = (-6.73   +  0.351*yy  -0.0013*yy*yy - 0.00016*yy*yy*yy);
  //double ret = (23.5+0.57*y-0.028*y*y-0.0003*y*y*y)+(0.77-0.044*y-5.4e-5*y*y+2.2e-5*y*y*y)*x+(0.078+0.00024*y-2.86e-6*y*y)*x*x;
  //double ret = (10.7+0.058*y-0.01*y*y)+x*(0.54-0.024*y-2.7e-5*y*y+1.3e-5*y*y*y)+x*x*(0.025+0.00027*y);
  double ret = (-0.3+0.35*y-0.024*y*y+3.8e-5*y*y*y+1.6e-5*y*y*y*y)+x*(0.75+0.0049*y-0.00075*y*y)+x*x*(0.024-0.0012*y-2.6e-5*y*y+7.2e-7*y*y*y);
  if(ret> 50) ret =  50;
  if(ret<-50) ret = -50;
  return 180 + 0.75*ret;
  //return 180 ;
    //return 180 + 250+yA1*TMath::Gaus(xx,yA2,40);
}



