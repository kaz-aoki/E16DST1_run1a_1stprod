  ~E16ANA_TrackCheckFile() { file.Write(); }
  void AddParam(E16ANA_TrackCandidates& cands) {
    auto& cand = cands.TrackCandidate(0);
//    sigma = cand.Sigma();
    each_sigmas0 = cand.EachSigma(0);
    each_sigmas1 = cand.EachSigma(1);
    each_sigmas2 = cand.EachSigma(2);
    each_sigmas3 = cand.EachSigma(3);
    init_pos_error = cand.InitPosError();
    tracking_max_steps = cand.TrackingMaxSteps();
    projection_max_steps = cand.ProjectionMaxSteps();
    for (int i = 0; i < 3; ++i) {
      gtr_time_difference_threshold[i] = cands.GTRTimeDiffThreshold(i);
    }
#ifndef TRACK_FIND_WO_TARGET
    for (int i = 0; i < 5; ++i) {
#else // TRACK_FIND_WO_TARGET
    for (int i = 0; i < 4; ++i) {
#endif // TRACK_FIND_WO_TARGET
      x_sigma[i] = cands.XSigma(i);
    }
    for (int i = 0; i < 3; ++i) {
      y_sigma[i] = cands.YSigma(i);
    }
    min_hits_in_x_cluster = cands.MinHitsInXCluster();
    gtr_y_diff_threshold = cands.GTRYDiffThreshold();
    for (int i = 0; i < 3; ++i) {
      gtr_peak_sum_threshold_x[i] = cands.GTRPeakSumThresholdX(i);
    }
    gtr_peak_sum_threshold_y= cands.GTRPeakSumThresholdY(0);
    for (int i = 0; i < 2; ++i) {
      rough_fit_chi_square_threshold[i] = cands.RoughFitChiSquareThreshold(i);
    }
    for (int i = 0; i < 3; ++i) {
      rough_x_fit_coefficient_threhold[i] = cands.RoughXFitCoefficientThreshold(i);
    }
    for (int i = 0; i < 2; ++i) {
      rough_y_fit_coefficient_threhold[i] = cands.RoughYFitCoefficientThreshold(i);
    }
    hbd_projection_threshold = cands.HBDProjectionThreshold();
    lg_projection_threshold = cands.LGProjectionThreshold();
    lg_electron_threshold = cands.LGElectronThreshold();
    for (int i = 0; i < 4; ++i) {
      residual_threshold_x[i] = cands.ResidualThresholdX(i);
      residual_threshold_y[i] = cands.ResidualThresholdY(i);
    }
    near_target_threshold = cands.NearTargetThreshold();
    step_track_step_size_cm = cands.StepTrackStepSizeCm();
    step_track_array_size= cands.StepTrackArraySize();
    vertex_sigma = cands.VertexSigma();
//    pair_fit_sigma0 = cands.PairFitSigma(0);
//    pair_fit_sigma1 = cands.PairFitSigma(1);
//    pair_fit_sigma2 = cands.PairFitSigma(2);
//    pair_fit_sigma3 = cands.PairFitSigma(3);
    t_param->Fill();
  }
  void AddRecord(E16ANA_GeometryV2& geometry, int _event_id, int _spill_id, uint64_t _timestamp_in_spill, int _trigger_fine_time, E16DST_DST1PhysicsRecord& record, E16ANA_LGBasic& lgbasic) {
    std::cout<<"event::"<<event_id <<std::endl;
    event_id = _event_id;
    spill_id = _spill_id;
    timestamp_in_spill = _timestamp_in_spill;
    trigger_fine_time = _trigger_fine_time;
#ifdef TRACK_EFF_CHECK
    cluster_merged = false;
#endif // TRACK_EFF_CHECK
#ifdef UseSTS
    n_ssd_hits = record.STS().NumHits();
#else 
    n_ssd_hits = record.SSD().NumHits();
#endif
    ssd_hit_id.resize(n_ssd_hits);
    ssd_hit_mid.resize(n_ssd_hits);
    ssd_hit_cid.resize(n_ssd_hits);
    ssd_hit_x.resize(n_ssd_hits);
    ssd_hit_gx.resize(n_ssd_hits);
    ssd_hit_gz.resize(n_ssd_hits);
    ssd_hit_t.resize(n_ssd_hits);
    ssd_hit_adc.resize(n_ssd_hits);
    for (int i = 0; i < n_ssd_hits; ++i) {
#ifdef UseSTS
      auto& hit = record.STS().Hit(i);
#else
      auto& hit = record.SSD().Hit(i);
#endif
//      ssd_hit_id[i] = i;
      ssd_hit_id[i] = hit.HitId();
      ssd_hit_mid[i] = hit.ModuleId();
      ssd_hit_cid[i] = hit.ChannelId();
      ssd_hit_x[i] = hit.LocalX();
      auto gpos = hit.GlobalPos(geometry);
      ssd_hit_gx[i] = gpos.X();
      ssd_hit_gz[i] = gpos.Z();
      ssd_hit_t[i] = hit.Timing();
      ssd_hit_adc[i] = hit.PeakHeight();
    }
    n_gtr100x_hits = 0;
    gtr100x_hit_id.clear();
    gtr100x_hit_mid.clear();
    gtr100x_hit_cid.clear();
    gtr100x_hit_x.clear();
    gtr100x_hit_tx.clear();
    gtr100x_hit_gx.clear();
    gtr100x_hit_gz.clear();
    gtr100x_hit_t.clear();
    gtr100x_hit_adc.clear();
    n_gtr200x_hits = 0;
    gtr200x_hit_id.clear();
    gtr200x_hit_mid.clear();
    gtr200x_hit_cid.clear();
    gtr200x_hit_x.clear();
    gtr200x_hit_tx.clear();
    gtr200x_hit_gx.clear();
    gtr200x_hit_gz.clear();
    gtr200x_hit_t.clear();
    gtr200x_hit_adc.clear();
    n_gtr300x_hits = 0;
    gtr300x_hit_id.clear();
    gtr300x_hit_mid.clear();
    gtr300x_hit_cid.clear();
    gtr300x_hit_x.clear();
    gtr300x_hit_tx.clear();
    gtr300x_hit_gx.clear();
    gtr300x_hit_gz.clear();
    gtr300x_hit_t.clear();
    gtr300x_hit_adc.clear();
    n_gtr100y_hits = 0;
    gtr100y_hit_id.clear();
    gtr100y_hit_mid.clear();
    gtr100y_hit_cid.clear();
    gtr100y_hit_y.clear();
    gtr100y_hit_ty.clear();
    gtr100y_hit_t.clear();
    gtr100y_hit_adc.clear();
    n_gtr100yb_hits = 0;
    gtr100yb_hit_id.clear();
    gtr100yb_hit_mid.clear();
    gtr100yb_hit_cid.clear();
    gtr100yb_hit_y.clear();
    gtr100yb_hit_ty.clear();
    gtr100yb_hit_t.clear();
    gtr100yb_hit_adc.clear();
    n_gtr200y_hits = 0;
    gtr200y_hit_id.clear();
    gtr200y_hit_mid.clear();
    gtr200y_hit_cid.clear();
    gtr200y_hit_y.clear();
    gtr200y_hit_ty.clear();
    gtr200y_hit_t.clear();
    gtr200y_hit_adc.clear();
    n_gtr300y_hits = 0;
    gtr300y_hit_id.clear();
    gtr300y_hit_mid.clear();
    gtr300y_hit_cid.clear();
    gtr300y_hit_y.clear();
    gtr300y_hit_ty.clear();
    gtr300y_hit_t.clear();
    gtr300y_hit_adc.clear();
    auto n_gtr_hits = record.GTR().NumHits();
    for (int i = 0; i < n_gtr_hits; ++i) {
      auto& hit = record.GTR().Hit(i);
      auto lid = hit.LayerId();
      auto type = hit.Type();
      if (lid == 0) {
        if (type == 0) {
          ++n_gtr100x_hits;
          gtr100x_hit_id.emplace_back(hit.HitId());
          gtr100x_hit_mid.emplace_back(hit.ModuleId());
          gtr100x_hit_cid.emplace_back(hit.ChannelId());
          gtr100x_hit_x.emplace_back(hit.LocalX());
	        gtr100x_hit_tx.emplace_back(hit.TdcPos());
          auto gpos = hit.GlobalPos(geometry);
          gtr100x_hit_gx.emplace_back(gpos.X());
          gtr100x_hit_gz.emplace_back(gpos.Z());
          gtr100x_hit_t.emplace_back(hit.Timing());
          gtr100x_hit_adc.emplace_back(hit.PeakHeight());
        } else if (type == 1) {
          ++n_gtr100y_hits;
          gtr100y_hit_id.emplace_back(hit.HitId());
          gtr100y_hit_mid.emplace_back(hit.ModuleId());
          gtr100y_hit_cid.emplace_back(hit.ChannelId());
          gtr100y_hit_y.emplace_back(hit.LocalX());
	        gtr100y_hit_ty.emplace_back(hit.TdcPos());
          gtr100y_hit_t.emplace_back(hit.Timing());
          gtr100y_hit_adc.emplace_back(hit.PeakHeight());
        } else {
          ++n_gtr100yb_hits;
          gtr100yb_hit_id.emplace_back(hit.HitId());
          gtr100yb_hit_mid.emplace_back(hit.ModuleId());
          gtr100yb_hit_cid.emplace_back(hit.ChannelId());
          gtr100yb_hit_y.emplace_back(hit.LocalX());
	        gtr100yb_hit_ty.emplace_back(hit.TdcPos());
          gtr100yb_hit_t.emplace_back(hit.Timing());
          gtr100yb_hit_adc.emplace_back(hit.PeakHeight());
        }
      } else if (lid == 1) {
        if (type == 0) {
          ++n_gtr200x_hits;
          gtr200x_hit_id.emplace_back(hit.HitId());
          gtr200x_hit_mid.emplace_back(hit.ModuleId());
          gtr200x_hit_cid.emplace_back(hit.ChannelId());
          gtr200x_hit_x.emplace_back(hit.LocalX());
	        gtr200x_hit_tx.emplace_back(hit.TdcPos());
          auto gpos = hit.GlobalPos(geometry);
          gtr200x_hit_gx.emplace_back(gpos.X());
          gtr200x_hit_gz.emplace_back(gpos.Z());
          gtr200x_hit_t.emplace_back(hit.Timing());
          gtr200x_hit_adc.emplace_back(hit.PeakHeight());
        } else if (type == 1) {
          ++n_gtr200y_hits;
          gtr200y_hit_id.emplace_back(hit.HitId());
          gtr200y_hit_mid.emplace_back(hit.ModuleId());
          gtr200y_hit_cid.emplace_back(hit.ChannelId());
          gtr200y_hit_y.emplace_back(hit.LocalX());
	        gtr200y_hit_ty.emplace_back(hit.TdcPos());
          gtr200y_hit_t.emplace_back(hit.Timing());
          gtr200y_hit_adc.emplace_back(hit.PeakHeight());
        }
      } else {
        if (type == 0) {
          ++n_gtr300x_hits;
          gtr300x_hit_id.emplace_back(hit.HitId());
          gtr300x_hit_mid.emplace_back(hit.ModuleId());
          gtr300x_hit_cid.emplace_back(hit.ChannelId());
          gtr300x_hit_x.emplace_back(hit.LocalX());
	        gtr300x_hit_tx.emplace_back(hit.TdcPos());
          auto gpos = hit.GlobalPos(geometry);
          gtr300x_hit_gx.emplace_back(gpos.X());
          gtr300x_hit_gz.emplace_back(gpos.Z());
          gtr300x_hit_t.emplace_back(hit.Timing());
          gtr300x_hit_adc.emplace_back(hit.PeakHeight());
        } else if (type == 1) {
          ++n_gtr300y_hits;
          gtr300y_hit_id.emplace_back(hit.HitId());
          gtr300y_hit_mid.emplace_back(hit.ModuleId());
          gtr300y_hit_cid.emplace_back(hit.ChannelId());
          gtr300y_hit_y.emplace_back(hit.LocalX());
	        gtr300y_hit_ty.emplace_back(hit.TdcPos());
          gtr300y_hit_t.emplace_back(hit.Timing());
          gtr300y_hit_adc.emplace_back(hit.PeakHeight());
        }
      }
    }
    n_hbd_hits = record.HBD().NumHits();
    hbd_hit_id.resize(n_hbd_hits);
    hbd_hit_mid.resize(n_hbd_hits);
    hbd_hit_cid.resize(n_hbd_hits);
    hbd_hit_x.resize(n_hbd_hits);
    hbd_hit_y.resize(n_hbd_hits);
    hbd_hit_gx.resize(n_hbd_hits);
    hbd_hit_gy.resize(n_hbd_hits);
    hbd_hit_gz.resize(n_hbd_hits);
    hbd_hit_t.resize(n_hbd_hits);
    hbd_hit_adc.resize(n_hbd_hits);
    for (int i = 0; i < n_hbd_hits; ++i) {
      auto& hit = record.HBD().Hit(i);
      hbd_hit_id[i] = hit.HitId();
      hbd_hit_mid[i] = hit.ModuleId();
      hbd_hit_cid[i] = hit.ModuleId();
      auto lpos = hit.LocalPos(geometry);
      hbd_hit_x[i] = lpos.X();
      hbd_hit_y[i] = lpos.Y();
      auto gpos = hit.GlobalPos(geometry);
      hbd_hit_gx[i] = gpos.X();
      hbd_hit_gy[i] = gpos.Y();
      hbd_hit_gz[i] = gpos.Z();
      hbd_hit_t[i] = hit.Timing();
      hbd_hit_adc[i] = hit.PeakHeight();
    }
#ifdef UseSTS
    n_ssd_clusters = record.STS().NumClusters();
#else
    n_ssd_clusters = record.SSD().NumClusters();
#endif
    ssd_cluster_id.resize(n_ssd_clusters);
    ssd_cluster_mid.resize(n_ssd_clusters);
    ssd_cluster_x.resize(n_ssd_clusters);
    ssd_cluster_gx.resize(n_ssd_clusters);
    ssd_cluster_gz.resize(n_ssd_clusters);
    ssd_cluster_adc.resize(n_ssd_clusters);
    ssd_cluster_t.resize(n_ssd_clusters);
    ssd_cluster_fit_x.resize(n_ssd_clusters);
    ssd_cluster_fit_t.resize(n_ssd_clusters);
    ssd_cluster_fit_adc.resize(n_ssd_clusters);
    ssd_cluster_fit_chi2.resize(n_ssd_clusters);
    ssd_cluster_size.resize(n_ssd_clusters);
#ifdef TRACK_EFF_CHECK
    ssd_cluster_is_merged.resize(n_ssd_clusters);
#endif // TRACK_EFF_CHECK
    for (int i = 0; i < n_ssd_clusters; ++i) {
#ifdef UseSTS
      auto& clst = record.STS().Cluster(i);
#else
      auto& clst = record.SSD().Cluster(i);
#endif
//      ssd_cluster_id[i] = i;
      ssd_cluster_id[i] = clst.ClusterId();
      ssd_cluster_mid[i] = clst.ModuleId();
      ssd_cluster_x[i] = clst.LocalX();
      auto gpos = clst.GlobalPos(geometry);
      ssd_cluster_gx[i] = gpos.X();
      ssd_cluster_gz[i] = gpos.Z();
      ssd_cluster_adc[i] = clst.PeakSum();
      ssd_cluster_t[i] = clst.Timing();
      ssd_cluster_size[i] = clst.NumHits();
      ssd_cluster_fit_x[i] = clst.LocalXFit();
      ssd_cluster_fit_t[i] = clst.TimingFit();
      ssd_cluster_fit_adc[i] = clst.PeakSumFit();
      ssd_cluster_fit_chi2[i] = clst.Chi2NdfFit();
#ifdef TRACK_EFF_CHECK
      ssd_cluster_is_merged[i] = clst.IsMerged();
      if (clst.IsMerged()) {
        cluster_merged = true;
      }
#endif // TRACK_EFF_CHECK
    }
    n_gtr100x_clusters = 0;
    n_gtr200x_clusters = 0;
    n_gtr300x_clusters = 0;
    n_gtr100y_clusters = 0;
    n_gtr100yb_clusters = 0;
    n_gtr200y_clusters = 0;
    n_gtr300y_clusters = 0;
    gtr100x_cluster_id.clear();
    gtr100x_cluster_mid.clear();
    gtr100x_cluster_x.clear();
    gtr100x_cluster_gx.clear();
    gtr100x_cluster_gz.clear();
    gtr100x_cluster_adc.clear();
    gtr100x_cluster_t.clear();
    gtr100x_cluster_size.clear();
    gtr200x_cluster_id.clear();
    gtr200x_cluster_mid.clear();
    gtr200x_cluster_x.clear();
    gtr200x_cluster_gx.clear();
    gtr200x_cluster_gz.clear();
    gtr200x_cluster_adc.clear();
    gtr200x_cluster_t.clear();
    gtr200x_cluster_size.clear();
    gtr300x_cluster_id.clear();
    gtr300x_cluster_mid.clear();
    gtr300x_cluster_x.clear();
    gtr300x_cluster_gx.clear();
    gtr300x_cluster_gz.clear();
    gtr300x_cluster_adc.clear();
    gtr300x_cluster_t.clear();
    gtr300x_cluster_size.clear();
    gtr100y_cluster_id.clear();
    gtr100y_cluster_mid.clear();
    gtr100y_cluster_y.clear();
