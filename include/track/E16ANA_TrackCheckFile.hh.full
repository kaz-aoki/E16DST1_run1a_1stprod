      auto& proj_hbd_clusters = cand.ProjectedHBDClusters();
      auto n_proj_hbd = proj_hbd_clusters.size();
      rk_proj_n_hbd[i] = n_proj_hbd;
      rk_proj_hbd_id[i].resize(n_proj_hbd);
      rk_proj_hbd_mid[i].resize(n_proj_hbd);
