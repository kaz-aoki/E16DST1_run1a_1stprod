      rk_proj_tgt0_gz[i] = proj_tgt0.Z();
      auto proj_tgt1 = cand.PosAtTarget(1);
      rk_proj_tgt1_gx[i] = proj_tgt1.X();
      rk_proj_tgt1_gy[i] = proj_tgt1.Y();
      rk_proj_tgt1_gz[i] = proj_tgt1.Z();
      auto proj_tgt2 = cand.PosAtTarget(2);
