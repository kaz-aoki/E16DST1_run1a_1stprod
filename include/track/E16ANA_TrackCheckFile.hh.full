      copy(hbd_ress.begin(), hbd_ress.end(), back_inserter(rough_fit_hbd_ress[i]));
      copy(hbd_y_oks.begin(), hbd_y_oks.end(), back_inserter(rough_fit_hbd_y_oks[i]));
